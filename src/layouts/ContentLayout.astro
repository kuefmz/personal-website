---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  meta?: string;
  image?: string;
  type?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, eyebrow, meta, image, type = "article", structuredData } = Astro.props;
---

<BaseLayout {title} {description} {image} {type} {structuredData}>
  <header class="content-header section">
    <div class="narrow">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="page-title">{title}</h1>
      <p class="content-description">{description}</p>
      {meta && <p class="content-meta">{meta}</p>}
    </div>
  </header>
  <div class="narrow content-body">
    <article class="prose">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .content-header {
    padding-bottom: 48px;
  }

  .content-description {
    max-width: 720px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.7vw, 1.25rem);
  }

  .content-meta {
    margin: 22px 0 0;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  .content-body {
    padding-bottom: clamp(64px, 8vw, 112px);
  }
</style>
