---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<header class="page-hero section">
  <div class="shell">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="page-title">{title}</h1>
    <p class="lead">{intro}</p>
  </div>
</header>

<style>
  .page-hero {
    padding-bottom: clamp(64px, 9vw, 120px);
  }

  .page-hero .lead {
    margin-top: 36px;
  }
</style>
