---
import Icon from "./Icon.astro";
---

<section class="contact-cta">
  <div class="shell cta-inner">
    <div>
      <p class="eyebrow">AI · knowledge graphs · ontology engineering</p>
      <h2>Have a related problem or research question?</h2>
    </div>
    <div>
      <p>
        Get in touch about research, engineering, or product work.
      </p>
      <div class="cta-actions">
        <a class="button button-primary" href="/contact/">
          Get in touch <Icon name="arrow" size={17} />
        </a>
        <a class="text-link" href="/publications/">Explore publications</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    padding-block: clamp(44px, 5vw, 68px);
    border-top: 1px solid var(--line);
    background: var(--accent-soft);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1.5fr 0.8fr;
    gap: clamp(30px, 5vw, 72px);
    align-items: end;
  }

  h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(1.8rem, 3.4vw, 3.25rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  .cta-inner > div:last-child p {
    margin: 0 0 28px;
    color: var(--muted);
  }

  .cta-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  @media (max-width: 760px) {
    .cta-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
