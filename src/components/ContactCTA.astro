---
import Icon from "./Icon.astro";
---

<section class="contact-cta">
  <div class="shell cta-inner">
    <div>
      <p class="eyebrow">AI · knowledge graphs · ontology engineering</p>
      <h2>Interested in the work behind these projects?</h2>
    </div>
    <div>
      <p>
        Follow the research record, explore the source code, or get in touch about a research,
        engineering, or product collaboration.
      </p>
      <div class="cta-actions">
        <a class="button button-primary" href="/contact/">
          Get in touch <Icon name="arrow" size={17} />
        </a>
        <a class="text-link" href="/publications/">Explore publications</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    padding-block: clamp(72px, 10vw, 128px);
    border-top: 1px solid var(--line);
    background: var(--accent-soft);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1.5fr 0.8fr;
    gap: clamp(36px, 8vw, 120px);
    align-items: end;
  }

  h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.4rem, 5.8vw, 5.6rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  .cta-inner > div:last-child p {
    margin: 0 0 28px;
    color: var(--muted);
  }

  .cta-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  @media (max-width: 760px) {
    .cta-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
