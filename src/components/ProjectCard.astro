---
import type { CollectionEntry } from "astro:content";
import { formatContentDate } from "../utils/contentDate";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const websiteLink = project.data.previewUrl
  ? project.data.links.find(({ href }) => href === project.data.previewUrl)
    ?? { label: "Visit live site", href: project.data.previewUrl }
  : undefined;
---

<article class:list={["card project-card", { "has-preview": Boolean(project.data.previewUrl) }]} data-category={project.data.category}>
  {
    project.data.previewUrl && (
      <div class="project-preview">
        <iframe
          src={project.data.previewUrl}
          title={`${project.data.title} website preview`}
          loading="lazy"
          tabindex="-1"
          referrerpolicy="strict-origin-when-cross-origin"
        />
        <a
          class="preview-link"
          href={project.data.previewUrl}
          target="_blank"
          rel="noreferrer"
          aria-label={`Open ${project.data.title} website in a new tab`}
        >
          <span>Open website</span>
        </a>
      </div>
    )
  }
  <div class="card-body">
    <div class="card-meta">
      <span>{project.data.category}</span>
      <span>{formatContentDate(project.data.date)}</span>
    </div>
    <h2><a href={`/projects/${project.id}/`}>{project.data.title}</a></h2>
    <p>{project.data.description}</p>
    <ul class="tag-list" aria-label="Technologies">
      {project.data.technologies.slice(0, 4).map((technology) => <li class="tag">{technology}</li>)}
    </ul>
    {
      websiteLink && (
        <a class="website-link" href={websiteLink.href} target="_blank" rel="noreferrer">
          {websiteLink.label} <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .website-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 24px;
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }

  .website-link:hover {
    text-decoration: underline;
  }

  .project-preview {
    position: relative;
    height: 210px;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .project-preview iframe {
    position: absolute;
    inset: 0;
    width: 160%;
    height: 160%;
    border: 0;
    pointer-events: none;
    transform: scale(0.625);
    transform-origin: top left;
  }

  .preview-link {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 14px;
    text-decoration: none;
  }

  .preview-link span {
    padding: 7px 10px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    background: rgba(9, 13, 36, 0.82);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .preview-link:hover span,
  .preview-link:focus-visible span {
    opacity: 1;
    transform: translateY(0);
  }

  .preview-link:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: -3px;
  }

  .project-card:not(.has-preview) .card-body {
    padding-top: clamp(28px, 4vw, 44px);
  }

  @media (hover: none) {
    .preview-link span {
      opacity: 1;
      transform: none;
    }
  }
</style>
