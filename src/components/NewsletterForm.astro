---
import { site } from "../data/site";

interface Props {
  compact?: boolean;
  heading?: string;
  intro?: string;
  buttonLabel?: string;
  source?: string;
  audience?: string;
  eventName?: string;
  initialStatus?: string;
  surface?: boolean;
}

const {
  compact = false,
  heading = "Occasional notes on AI, knowledge systems, and building products.",
  intro = "No content treadmill. Just useful research notes, engineering lessons, and project updates.",
  buttonLabel = "Join by email",
  source = "",
  audience = "",
  eventName = "newsletter_signup",
  initialStatus = "Your address will be added to the private newsletter list.",
  surface = false,
} = Astro.props;
---

<form
  class:list={["newsletter-form", { compact, surface }]}
  data-newsletter-form
  data-endpoint={site.formsEndpoint}
  data-event-name={eventName}
  data-source={source}
  data-audience={audience}
>
  <input type="hidden" name="type" value="newsletter" />
  {source && <input type="hidden" name="source" value={source} />}
  {audience && <input type="hidden" name="audience" value={audience} />}
  <label class="form-honeypot" aria-hidden="true">
    <span>Website</span>
    <input type="text" name="website" tabindex="-1" autocomplete="off" />
  </label>

  {!compact && (
    <>
      <p class="eyebrow">Newsletter</p>
      <h2>{heading}</h2>
      <p class="newsletter-intro">
        {intro}
      </p>
    </>
  )}

  <div class="newsletter-fields">
    <label>
      <span class="sr-only">Email address</span>
      <input type="email" name="email" placeholder="you@example.com" autocomplete="email" required />
    </label>
    <button class:list={["button", compact ? "button-light" : "button-primary"]} type="submit">
      {buttonLabel}
    </button>
  </div>
  <label class="consent">
    <input type="checkbox" name="consent" value="Yes" required />
    <span>
      I would like to receive occasional emails and agree that my address may be stored for this purpose.
    </span>
  </label>
  <p class="form-status email-note" aria-live="polite">
    {initialStatus}
  </p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>("[data-newsletter-form]").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;

      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const status = form.querySelector<HTMLElement>(".form-status");
      const endpoint = form.dataset.endpoint;
      const originalLabel = button?.textContent ?? "Join newsletter";
      const eventName = form.dataset.eventName || "newsletter_signup";
      const source = form.dataset.source || "";
      const audience = form.dataset.audience || "";

      if (!endpoint || !button || !status) return;

      button.disabled = true;
      button.textContent = "Joining…";
      status.textContent = "Submitting your email address…";

      try {
        const data = new FormData(form);
        const payload = {
          type: "newsletter",
          email: String(data.get("email") ?? "").trim(),
          website: String(data.get("website") ?? ""),
          source: String(data.get("source") ?? source),
          audience: String(data.get("audience") ?? audience),
        };

        await fetch(endpoint, {
          method: "POST",
          mode: "no-cors",
          headers: {
            "Content-Type": "text/plain;charset=UTF-8",
          },
          body: JSON.stringify(payload),
        });
        form.reset();
        status.textContent = "Thank you. Your subscription request has been received.";
        const dataLayerWindow = window as Window & { dataLayer?: unknown[] };
        dataLayerWindow.dataLayer = dataLayerWindow.dataLayer || [];
        dataLayerWindow.dataLayer.push({
          event: eventName,
          source,
          audience,
        });
      } catch {
        status.textContent = "The request could not be sent. Please try again.";
      } finally {
        button.disabled = false;
        button.textContent = originalLabel;
      }
    });
  });
</script>

<style>
  .newsletter-form:not(.compact) {
    max-width: 760px;
    padding: clamp(26px, 4vw, 42px);
    border: 1px solid var(--line);
    background: var(--panel);
  }

  h2 {
    max-width: 680px;
    margin: 0;
    font-size: clamp(1.7rem, 3.2vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1.02;
  }

  .newsletter-intro {
    max-width: 620px;
    margin: 18px 0 0;
    color: var(--muted);
  }

  .newsletter-fields {
    display: flex;
    gap: 10px;
    margin-top: 24px;
  }

  .newsletter-fields label {
    flex: 1;
  }

  .newsletter-fields input {
    width: 100%;
    min-height: 48px;
    padding: 0 14px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--input-bg);
    color: var(--ink);
  }

  .consent {
    display: flex;
    max-width: 620px;
    align-items: flex-start;
    gap: 9px;
    margin-top: 14px;
    color: var(--muted);
    font-size: 0.7rem;
    line-height: 1.5;
  }

  .consent input {
    margin-top: 3px;
    accent-color: var(--accent);
  }

  .email-note {
    margin: 8px 0 0;
    color: var(--faint);
    font-size: 0.66rem;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
  }

  .newsletter-form button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .compact {
    max-width: 440px;
  }

  .compact .newsletter-fields {
    margin-top: 0;
  }

  .compact .newsletter-fields input {
    border-color: rgba(220, 210, 245, 0.24);
    background: rgba(255, 255, 255, 0.06);
    color: #f8f7fc;
  }

  .compact .newsletter-fields input::placeholder {
    color: #969189;
  }

  .button-light {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .compact .consent {
    color: #918c84;
  }

  .compact .email-note {
    color: #777280;
  }

  .surface.compact {
    background: var(--surface);
    color: var(--ink);
  }

  .surface.compact .newsletter-fields input {
    border-color: var(--line-strong);
    background: #fff;
    color: #181317;
  }

  .surface.compact .newsletter-fields input::placeholder {
    color: #766b72;
  }

  .surface.compact .consent {
    color: var(--muted);
  }

  .surface.compact .email-note {
    color: var(--faint);
  }

  @media (max-width: 560px) {
    .newsletter-fields {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
