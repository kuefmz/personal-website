---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import NewsletterForm from "../components/NewsletterForm.astro";

const reminders = [
  "The right routine makes motivation optional.",
  "Peace begins when honesty becomes safer than denial.",
  "Your future starts when you stop negotiating with the work.",
  "Make today so honest that tomorrow trusts you.",
  "The next chapter needs your attention, not your fear.",
  "Small promises kept daily become self-trust.",
] as const;
---

<BaseLayout
  title="Built in Silence | Mindset & Discipline"
  titleSuffix={false}
  description="Quiet discipline, honest growth, and practical reminders for people building a better life one day at a time."
  canonicalUrl="https://jeniferciuciukiss.com/mindset"
>
  <section class="mindset-hero">
    <div class="shell mindset-hero-grid">
      <div class="mindset-copy">
        <p class="eyebrow">Mindset</p>
        <h1 class="display">Built in Silence</h1>
        <p class="hero-subtitle">
          Quiet discipline, honest growth, and practical reminders for people building a better life one day at a time.
        </p>
        <p class="hero-intro">
          A quiet space for discipline, clarity, and becoming the version of yourself you keep imagining.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="#newsletter" data-mindset-cta="newsletter">
            Join the Mindset Newsletter <Icon name="arrow" />
          </a>
          <a class="button button-quiet" href="#reminders" data-mindset-cta="reminders">
            Read the latest reminders
          </a>
        </div>
      </div>
      <aside class="hero-note" aria-label="Built in Silence focus">
        <p>Discipline</p>
        <p>Clarity</p>
        <p>Self-trust</p>
      </aside>
    </div>
  </section>

  <section id="newsletter" class="section newsletter-section">
    <div class="shell newsletter-layout">
      <div>
        <p class="eyebrow">Newsletter</p>
        <h2 class="section-title">Get one honest reminder every week</h2>
        <p class="lead">
          Short reflections on discipline, focus, self-trust, and building a life you are proud of — without noise,
          hype, or spam.
        </p>
      </div>
      <NewsletterForm
        compact
        surface
        buttonLabel="Join newsletter"
        source="mindset"
        audience="motivation"
        eventName="newsletter_signup"
        initialStatus="One honest reminder each week. No noise."
      />
    </div>
  </section>

  <section id="reminders" class="section reminders-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Reminders</p>
          <h2 class="section-title">Quiet notes for the day you are in.</h2>
        </div>
        <p class="lead">
          Save what steadies you, return when you need focus, and let the work become a little simpler.
        </p>
      </div>
      <div class="reminder-grid">
        {
          reminders.map((reminder) => (
            <article class="reminder-card">
              <p>{reminder}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-compact about-mindset">
    <div class="shell split-section">
      <div>
        <p class="eyebrow">About</p>
        <h2 class="section-title">Why <emp>Built in Silence?</emp></h2>
      </div>
      <p class="lead">
        I created this space for people who are quietly rebuilding themselves — through discipline, better habits,
        deeper honesty, and small daily actions. Some lessons come from research, some from running, some from
        building projects, and some from simply trying again.
      </p>
    </div>
  </section>

  <section class="section coming-soon-section">
    <div class="shell coming-soon">
      <div>
        <p class="eyebrow">Coming soon</p>
        <h2 class="section-title">The Discipline Playbook</h2>
        <p class="lead">
          A simple digital guide with practical prompts, routines, and reflection exercises.
        </p>
      </div>
      <button class="button button-quiet" type="button" disabled>Coming soon</button>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>("[data-mindset-cta]").forEach((cta) => {
    cta.addEventListener("click", () => {
      const dataLayerWindow = window as Window & { dataLayer?: unknown[] };
      dataLayerWindow.dataLayer = dataLayerWindow.dataLayer || [];
      dataLayerWindow.dataLayer.push({
        event: "mindset_cta_click",
        cta: cta.dataset.mindsetCta,
      });
    });
  });
</script>

<style>
  .mindset-hero {
    padding-block: clamp(52px, 7vw, 108px);
    border-bottom: 1px solid var(--line);
  }

  .mindset-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.34fr);
    gap: clamp(32px, 6vw, 78px);
    align-items: end;
  }

  .mindset-copy :global(.display) {
    max-width: 840px;
    font-size: clamp(3.4rem, 8vw, 7.4rem);
  }

  .hero-subtitle,
  .hero-intro {
    max-width: 720px;
    margin: 22px 0 0;
    color: var(--muted);
  }

  .hero-subtitle {
    font-size: clamp(1.08rem, 1.6vw, 1.32rem);
    line-height: 1.5;
  }

  .hero-intro {
    font-family: var(--font-serif);
    font-size: clamp(1.22rem, 2vw, 1.72rem);
    line-height: 1.45;
  }

  .hero-note {
    display: grid;
    gap: 12px;
    padding: clamp(18px, 2.5vw, 26px);
    border: 1px solid var(--line);
    background: var(--panel);
    box-shadow: 0 20px 60px var(--shadow);
  }

  .hero-note p {
    margin: 0;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-note p:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .newsletter-layout,
  .split-section,
  .coming-soon {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(28px, 5vw, 68px);
    align-items: start;
  }

  .newsletter-layout :global(.compact) {
    width: 100%;
    max-width: none;
    padding: clamp(22px, 3vw, 32px);
    border: 1px solid var(--line);
    box-shadow: 0 18px 52px var(--shadow);
  }

  .newsletter-layout :global(.compact .newsletter-fields) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
  }

  .newsletter-layout :global(.compact .newsletter-fields .button-light) {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .reminders-section {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .reminder-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .reminder-card {
    min-height: 190px;
    padding: clamp(20px, 2.4vw, 28px);
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .reminder-card p {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.28rem, 2vw, 1.82rem);
    line-height: 1.25;
  }

  .about-mindset {
    border-bottom: 1px solid var(--line);
  }

  .coming-soon {
    align-items: center;
    padding: clamp(24px, 4vw, 42px);
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .coming-soon .button {
    justify-self: end;
  }

  .coming-soon .button:disabled {
    cursor: not-allowed;
    opacity: 0.58;
    transform: none;
  }

  @media (max-width: 820px) {
    .mindset-hero-grid,
    .newsletter-layout,
    .split-section,
    .coming-soon {
      grid-template-columns: 1fr;
    }

    .hero-note {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-note p {
      padding: 0;
      border: 0;
    }

    .reminder-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .coming-soon .button {
      justify-self: start;
    }
  }

  @media (max-width: 560px) {
    .mindset-copy :global(.display) {
      font-size: clamp(3.2rem, 18vw, 5rem);
    }

    .hero-note,
    .reminder-grid,
    .newsletter-layout :global(.compact .newsletter-fields) {
      grid-template-columns: 1fr;
    }

    .reminder-card {
      min-height: 150px;
    }
  }
</style>
