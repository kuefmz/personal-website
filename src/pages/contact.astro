---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Contact Jenifer Ciuciu-Kiss about research, AI and data engineering, knowledge graphs, publications, and product collaboration."
>
  <section id="project-request" class="contact-form-section">
    <div class="shell form-layout">
      <header class="form-heading">
        <p class="eyebrow">Contact</p>
        <h1 class="section-title">Tell me what you’re working on.</h1>
        <p class="form-intro">
          Send a project request or start a conversation about research, engineering, or products.
        </p>
        <p class="form-note">
          Prefer writing directly? <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </header>

      <form class="project-form" data-project-form data-endpoint={site.formsEndpoint}>
        <label class="form-honeypot" aria-hidden="true">
          <span>Website</span>
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>

        <div class="form-row">
          <label>
            <span>Name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>
          <label>
            <span>Work email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
        </div>

        <div class="form-row">
          <label>
            <span>Company</span>
            <input type="text" name="company" autocomplete="organization" />
          </label>
          <label>
            <span>Project stage</span>
            <select name="project_stage" required>
              <option value="">Select one</option>
              <option>Exploring the problem</option>
              <option>Ready for a prototype</option>
              <option>Need production implementation</option>
              <option>Need technical advice</option>
            </select>
          </label>
        </div>

        <label>
          <span>What would you like to automate?</span>
          <textarea
            name="project_description"
            rows="6"
            placeholder="Describe the current process, who uses it, and what makes it difficult."
            required
          ></textarea>
        </label>

        <div class="form-row">
          <label>
            <span>Current tools or systems</span>
            <input type="text" name="current_tools" placeholder="Optional" />
          </label>
          <label>
            <span>Target timeline</span>
            <select name="timeline">
              <option value="">Flexible / not sure</option>
              <option>Within one month</option>
              <option>1–3 months</option>
              <option>3–6 months</option>
              <option>Longer-term initiative</option>
            </select>
          </label>
        </div>

        <label class="consent">
          <input type="checkbox" name="consent" value="Yes" required />
          <span>
            I agree that my details may be stored and used to respond to this request.
            Please do not include confidential or regulated data.
          </span>
        </label>

        <button class="button button-primary submit-button" type="submit">
          Send project request <Icon name="arrow" size={17} />
        </button>
        <p class="form-status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const projectForm = document.querySelector<HTMLFormElement>("[data-project-form]");

  projectForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!projectForm.reportValidity()) return;

    const button = projectForm.querySelector<HTMLButtonElement>('button[type="submit"]');
    const status = projectForm.querySelector<HTMLElement>(".form-status");
    const endpoint = projectForm.dataset.endpoint;

    if (!button || !status || !endpoint) return;

    button.disabled = true;
    status.textContent = "Sending your request…";

    try {
      const data = new FormData(projectForm);
      const payload = {
        type: "form",
        name: String(data.get("name") ?? "").trim(),
        email: String(data.get("email") ?? "").trim(),
        company: String(data.get("company") ?? "").trim(),
        projectStage: String(data.get("project_stage") ?? ""),
        automationGoal: String(data.get("project_description") ?? "").trim(),
        currentTools: String(data.get("current_tools") ?? "").trim(),
        timeline: String(data.get("timeline") ?? ""),
        website: String(data.get("website") ?? ""),
      };

      await fetch(endpoint, {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "text/plain;charset=UTF-8",
        },
        body: JSON.stringify(payload),
      });
      projectForm.reset();
      status.textContent = "Thank you. Your project request has been received.";
      const dataLayerWindow = window as Window & { dataLayer?: unknown[] };
      dataLayerWindow.dataLayer = dataLayerWindow.dataLayer || [];
      dataLayerWindow.dataLayer.push({
        event: "contact_form_submit",
      });
    } catch {
      status.textContent = "The request could not be sent. Please try again or email me directly.";
    } finally {
      button.disabled = false;
    }
  });
</script>

<style>
  .contact-form-section {
    padding-block: clamp(38px, 5vw, 62px);
    scroll-margin-top: 24px;
  }

  .form-layout {
    display: grid;
    grid-template-columns: minmax(240px, 0.6fr) minmax(0, 1.4fr);
    gap: clamp(32px, 5vw, 68px);
    align-items: start;
  }

  .form-heading {
    position: sticky;
    top: 32px;
  }

  .form-intro {
    max-width: 430px;
    margin: 22px 0 0;
    color: var(--muted);
  }

  .form-note {
    margin: 18px 0 0;
    color: var(--faint);
    font-size: 0.78rem;
  }

  .form-note a {
    color: var(--accent-dark);
  }

  .project-form {
    display: flex;
    gap: 17px;
    padding: clamp(22px, 3vw, 34px);
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel);
    box-shadow: 0 20px 60px var(--shadow);
    flex-direction: column;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .project-form label:not(.consent) {
    display: flex;
    gap: 8px;
    flex-direction: column;
  }

  .project-form label > span:first-child {
    font-size: 0.76rem;
    font-weight: 600;
  }

  .project-form input:not([type="checkbox"]),
  .project-form select,
  .project-form textarea {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    outline: 0;
    background: var(--input-bg);
    color: var(--ink);
  }

  .project-form input:focus,
  .project-form select:focus,
  .project-form textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-soft);
  }

  .project-form textarea {
    min-height: 130px;
    resize: vertical;
  }

  .consent {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    color: var(--muted);
    font-size: 0.73rem;
    line-height: 1.5;
  }

  .consent input {
    margin-top: 3px;
    accent-color: var(--accent);
  }

  .submit-button {
    align-self: flex-start;
  }

  .submit-button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .form-status {
    min-height: 1.5em;
    margin: -6px 0 0;
    color: var(--muted);
    font-size: 0.76rem;
  }

  @media (max-width: 820px) {
    .form-layout {
      grid-template-columns: 1fr;
    }

    .form-heading {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
