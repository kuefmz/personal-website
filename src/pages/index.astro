---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { contentDateSortValue, formatContentDate } from "../utils/contentDate";

const latestProject = (await getCollection("projects")).sort(
  (a, b) => contentDateSortValue(b.data.date) - contentDateSortValue(a.data.date)
    || a.data.title.localeCompare(b.data.title),
)[0];
const latestPublication = (await getCollection("publications")).sort(
  (a, b) => contentDateSortValue(b.data.date) - contentDateSortValue(a.data.date)
    || a.data.title.localeCompare(b.data.title),
)[0];
const latestPost = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
)[0];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { day: "numeric", month: "long", year: "numeric" }).format(date);

const latest = [
  {
    type: "Project",
    date: formatContentDate(latestProject.data.date),
    title: latestProject.data.title,
    description: latestProject.data.description,
    href: `/projects/${latestProject.id}/`,
  },
  {
    type: "Publication",
    date: formatContentDate(latestPublication.data.date),
    title: latestPublication.data.title,
    description: latestPublication.data.abstract,
    href: `/publications/${latestPublication.id}/`,
  },
  {
    type: "Blog",
    date: formatDate(latestPost.data.publishedAt),
    title: latestPost.data.title,
    description: latestPost.data.description,
    href: `/blog/${latestPost.id}/`,
  },
];

const organizations = [
  { name: "UBS", logo: "/images/organizations/ubs.svg" },
  { name: "UPM", logo: "/images/organizations/upm.png" },
  { name: "ISWC", logo: "/images/organizations/iswc.webp" },
  { name: "DBpedia", logo: "/images/organizations/dbpedia.jpeg" },
  { name: "Sense6", logo: "/images/organizations/sense6.jpeg" },
  { name: "Parquery", logo: "/images/organizations/parquery.png" },
  { name: "Le Wagon", logo: "/images/organizations/le-wagon.svg" },
  { name: "ELTE", logo: "/images/organizations/elte.jpeg" },
] as const;
---

<BaseLayout
  description="Jenifer Ciuciu-Kiss is an AI engineer and PhD researcher working on knowledge graphs, ontology engineering, data systems, and research software."
>
  <section class="home-hero">
    <div class="network-field" aria-hidden="true">
      <span class="network-line line-a"></span>
      <span class="network-line line-b"></span>
      <span class="network-line line-c"></span>
      <span class="network-line line-d"></span>
      <span class="network-node node-a"></span>
      <span class="network-node node-b"></span>
      <span class="network-node node-c"></span>
      <span class="network-node node-d"></span>
      <span class="network-node node-e"></span>
    </div>
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI Engineer · PhD Researcher · Product Builder</p>
        <h1 class="display">Building the knowledge systems behind <em>intelligent products.</em></h1>
        <p class="hero-intro">
          I work across AI, knowledge graphs, ontology engineering, data engineering, and
          research software.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/projects/">
            View projects <Icon name="arrow" />
          </a>
          <a class="button button-quiet" href="/publications/">View publications</a>
        </div>
      </div>
      <aside class="capability-panel" aria-label="Areas of work">
        <p class="capability-intro">
          I work at the intersection of <br>
          <strong>AI, data, and knowledge.</strong>
        </p>
        <div class="capability-list">
          <article class="capability">
            <span class="capability-mark" aria-hidden="true">▣</span>
            <div>
              <h2>AI &amp; Data Engineering</h2>
              <p>Data-driven systems and automation.</p>
            </div>
          </article>
          <article class="capability">
            <span class="capability-mark" aria-hidden="true">↗</span>
            <div>
              <h2>Products &amp; Websites</h2>
              <p>Digital products built to last.</p>
            </div>
          </article>
          <article class="capability">
            <span class="capability-mark capability-code" aria-hidden="true">&lt;/&gt;</span>
            <div>
              <h2>Research &amp; Innovation</h2>
              <p>Research translated into practice.</p>
            </div>
          </article>
          <article class="capability">
            <span class="capability-mark" aria-hidden="true">◇</span>
            <div>
              <h2>Knowledge Graphs &amp; Ontologies</h2>
              <p>Structured knowledge for intelligent systems.</p>
            </div>
          </article>
        </div>
      </aside>
    </div>

    <div class="shell experience-strip">
      <div class="experience-heading">
        <span>Experience across</span>
      </div>
      <div class="logo-marquee" aria-label={`Experience across ${organizations.map(({ name }) => name).join(", ")}`}>
        <div class="logo-track">
          {
            organizations.map(({ name, logo }) => (
              <span class="organization-logo">
                {logo ? <img src={logo} alt={name} loading="lazy" /> : <strong>{name}</strong>}
              </span>
            ))
          }
        </div>
        <div class="logo-track" aria-hidden="true">
          {
            organizations.map(({ name, logo }) => (
              <span class="organization-logo">
                {logo ? <img src={logo} alt="" loading="lazy" /> : <strong>{name}</strong>}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="latest section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Latest</p>
          <h2 class="section-title">Recent work.</h2>
        </div>
      </div>

      <div class="latest-grid">
        {
          latest.map((item) => (
            <article class="latest-card">
              <div class="latest-meta">
                <span>{item.type}</span>
                <span>{item.date}</span>
              </div>
              <h3><a href={item.href}>{item.title}</a></h3>
              <a class="latest-link" href={item.href}>
                View {item.type.toLowerCase()} <Icon name="arrow" size={16} />
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(40px, 5vw, 64px) 0 28px;
  }

  .home-hero :global(.display) {
    max-width: 760px;
    font-size: clamp(2.6rem, 5vw, 4.85rem);
    line-height: 0.98;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(340px, 0.82fr);
    gap: clamp(30px, 4vw, 56px);
    align-items: center;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero-intro {
    max-width: 680px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: clamp(0.96rem, 1.2vw, 1.08rem);
  }

  .hero-copy :global(.button-row) {
    margin-top: 22px;
  }

  .capability-panel {
    position: relative;
    z-index: 2;
    padding: clamp(20px, 2.4vw, 28px);
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel);
    box-shadow: 0 24px 70px var(--shadow);
    backdrop-filter: blur(20px);
  }

  .capability-intro {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.4vw, 1.28rem);
    line-height: 1.45;
  }

  .capability-intro strong {
    color: var(--accent-dark);
    font-weight: 600;
  }

  .capability-list {
    border-top: 1px solid var(--line);
  }

  .capability {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
  }

  .capability:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .capability-mark {
    padding-top: 2px;
    color: var(--accent-dark);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-align: center;
  }

  .capability-code {
    font-size: 0.7rem;
  }

  .capability h2 {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 650;
    letter-spacing: -0.015em;
  }

  .capability p {
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 0.71rem;
    line-height: 1.55;
  }

  .experience-strip {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 24px;
    align-items: center;
    padding: 16px 20px;
    margin-top: clamp(28px, 4vw, 44px);
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--panel);
    box-shadow: 0 24px 70px var(--shadow);
    backdrop-filter: blur(20px);
  }

  .experience-heading {
    display: flex;
    min-width: 132px;
    flex-direction: column;
    gap: 3px;
    color: var(--faint);
    font-size: 0.68rem;
  }

  .experience-heading span {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-heading strong {
    color: var(--muted);
    font-weight: 500;
  }

  .logo-marquee {
    display: flex;
    overflow: hidden;
    min-width: 0;
    padding-block: 6px;
    mask-image: linear-gradient(90deg, transparent, black 7%, black 93%, transparent);
  }

  .logo-track {
    display: flex;
    min-width: max-content;
    align-items: center;
    animation: logo-scroll 30s linear infinite;
  }

  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }

  .organization-logo {
    display: inline-flex;
    min-width: 136px;
    align-items: center;
    justify-content: center;
    padding-inline: 22px;
    color: var(--muted);
    white-space: nowrap;
  }

  .organization-logo img {
    width: auto;
    max-width: 104px;
    height: 28px;
    object-fit: contain;
    opacity: 0.58;
  }

  .organization-logo strong {
    font-size: 0.92rem;
    letter-spacing: 0.025em;
  }

  :global([data-theme="dark"]) .organization-logo img {
    opacity: 0.7;
  }

  @keyframes logo-scroll {
    to {
      transform: translateX(-100%);
    }
  }

  .network-field {
    position: absolute;
    z-index: 0;
    inset: auto -10% -8% -10%;
    height: 48%;
    opacity: 0.8;
    background:
      radial-gradient(ellipse at 25% 90%, rgba(30, 67, 230, 0.25), transparent 38%),
      radial-gradient(ellipse at 80% 80%, rgba(229, 34, 173, 0.32), transparent 40%);
  }

  .network-line {
    position: absolute;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(112, 78, 232, 0.7), rgba(235, 45, 178, 0.7), transparent);
    transform-origin: left;
  }

  .line-a { left: 8%; bottom: 26%; width: 35%; transform: rotate(-8deg); }
  .line-b { left: 30%; bottom: 32%; width: 34%; transform: rotate(10deg); }
  .line-c { right: 9%; bottom: 25%; width: 38%; transform: rotate(-13deg); }
  .line-d { left: 62%; bottom: 18%; width: 24%; transform: rotate(22deg); }

  .network-node {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 16px var(--accent);
  }

  .node-a { left: 12%; bottom: 28%; }
  .node-b { left: 34%; bottom: 37%; }
  .node-c { left: 58%; bottom: 27%; }
  .node-d { right: 18%; bottom: 36%; }
  .node-e { right: 5%; bottom: 18%; }

  .latest {
    border-top: 1px solid var(--line);
    background: rgba(9, 13, 36, 0.62);
  }

  .latest.section {
    padding-block: clamp(44px, 5vw, 68px);
  }

  :global([data-theme="light"]) .latest {
    background: var(--surface);
  }

  .linkedin-feed {
    border-top: 1px solid var(--line);
  }

  .linkedin-feed.section {
    padding-block: clamp(44px, 5vw, 72px);
  }

  .linkedin-feed .section-heading {
    margin-bottom: clamp(22px, 3vw, 34px);
  }

  .linkedin-widget {
    width: min(100%, 860px);
    min-height: 360px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
  }

  .linkedin-widget :global(.sk-ww-linkedin-page-post) {
    width: 100%;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid var(--line);
  }

  .latest-card {
    display: flex;
    min-height: 275px;
    padding: clamp(20px, 2vw, 26px);
    flex-direction: column;
    background: var(--panel);
  }

  .latest-card + .latest-card {
    border-left: 1px solid var(--line);
  }

  .latest-meta {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    text-transform: uppercase;
  }

  .latest-card h3 {
    margin: 34px 0 14px;
    font-size: clamp(1.22rem, 1.7vw, 1.65rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .latest-card h3 a {
    text-decoration: none;
  }

  .latest-card h3 a:hover {
    color: var(--accent-dark);
  }

  .latest-card > p {
    margin: 0 0 32px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .latest-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: auto;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .capability-panel {
      margin-top: 4px;
    }

    .experience-strip {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 20px 0;
    }

    .experience-heading {
      padding-inline: 20px;
    }

    .latest-grid {
      grid-template-columns: 1fr;
    }

    .latest-card {
      min-height: 245px;
    }

    .latest-card + .latest-card {
      border-top: 1px solid var(--line);
      border-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-marquee {
      overflow-x: auto;
      mask-image: none;
    }

    .logo-track {
      animation: none;
    }

    .logo-track[aria-hidden="true"] {
      display: none;
    }
  }
</style>
