---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const latestProject = (await getCollection("projects")).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order || a.data.title.localeCompare(b.data.title),
)[0];
const latestPublication = (await getCollection("publications")).sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order || a.data.title.localeCompare(b.data.title),
)[0];
const latestPost = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
)[0];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { day: "numeric", month: "long", year: "numeric" }).format(date);

const latest = [
  {
    type: "Project",
    date: String(latestProject.data.year),
    title: latestProject.data.title,
    description: latestProject.data.description,
    href: `/projects/${latestProject.id}/`,
  },
  {
    type: "Publication",
    date: String(latestPublication.data.year),
    title: latestPublication.data.title,
    description: latestPublication.data.abstract,
    href: `/publications/${latestPublication.id}/`,
  },
  {
    type: "Blog",
    date: formatDate(latestPost.data.publishedAt),
    title: latestPost.data.title,
    description: latestPost.data.description,
    href: `/blog/${latestPost.id}/`,
  },
];

const organizations = [
  { name: "UBS", logo: "/images/organizations/ubs.svg" },
  { name: "UPM", logo: "/images/organizations/upm.png" },
  { name: "ISWC", logo: "/images/organizations/iswc.webp" },
  { name: "DBpedia", logo: "/images/organizations/dbpedia.jpeg" },
  { name: "Sense6", logo: "/images/organizations/sense6.jpeg" },
  { name: "Parquery", logo: "/images/organizations/parquery.png" },
  { name: "Le Wagon", logo: "/images/organizations/le-wagon.svg" },
  { name: "ELTE", logo: "/images/organizations/elte.jpeg" },
] as const;
---

<BaseLayout
  description="Building intelligent systems through AI, knowledge graphs, and ontology engineering. Jenifer Tabita Ciuciu-Kiss designs knowledge systems behind useful products."
>
  <section class="home-hero">
    <div class="network-field" aria-hidden="true">
      <span class="network-line line-a"></span>
      <span class="network-line line-b"></span>
      <span class="network-line line-c"></span>
      <span class="network-line line-d"></span>
      <span class="network-node node-a"></span>
      <span class="network-node node-b"></span>
      <span class="network-node node-c"></span>
      <span class="network-node node-d"></span>
      <span class="network-node node-e"></span>
    </div>
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI · knowledge graphs · ontology engineering</p>
        <h1 class="display">Building the knowledge systems behind <em>intelligent products.</em></h1>
        <p class="hero-intro">
          I design knowledge graphs, ontologies, AI systems, and data platforms that transform
          complex information into real-world applications.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/projects/">
            Explore my work <Icon name="arrow" />
          </a>
          <a class="button button-quiet" href="/about/">About me</a>
        </div>
      </div>
      <aside class="capability-panel">
        <p class="panel-intro">I work at the intersection of <strong>AI, data, and knowledge.</strong></p>
        <div class="capability-list">
          <article>
            <span class="capability-icon">▣</span>
            <div>
              <h2>AI & Data Engineering</h2>
              <p>Building scalable pipelines, retrieval systems, and intelligent applications.</p>
            </div>
          </article>
          <article>
            <span class="capability-icon">↗</span>
            <div>
              <h2>Products & Websites</h2>
              <p>Turning ideas and technical foundations into practical digital experiences.</p>
            </div>
          </article>
          <article>
            <span class="capability-icon">&lt;/&gt;</span>
            <div>
              <h2>Research & Innovation</h2>
              <p>Publishing research and developing tools that make scientific work reusable.</p>
            </div>
          </article>
          <article>
            <span class="capability-icon">◇</span>
            <div>
              <h2>Knowledge Graphs & Ontologies</h2>
              <p>Designing structured knowledge systems that machines and humans can trust.</p>
            </div>
          </article>
        </div>
      </aside>
    </div>

    <div class="shell experience-strip">
      <div class="experience-heading">
        <span>Experience across</span>
      </div>
      <div class="logo-marquee" aria-label={`Experience across ${organizations.map(({ name }) => name).join(", ")}`}>
        <div class="logo-track">
          {
            organizations.map(({ name, logo }) => (
              <span class="organization-logo">
                {logo ? <img src={logo} alt={name} loading="lazy" /> : <strong>{name}</strong>}
              </span>
            ))
          }
        </div>
        <div class="logo-track" aria-hidden="true">
          {
            organizations.map(({ name, logo }) => (
              <span class="organization-logo">
                {logo ? <img src={logo} alt="" loading="lazy" /> : <strong>{name}</strong>}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="latest section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Latest</p>
          <h2 class="section-title">New work and notes.</h2>
        </div>
        <p class="lead">
          The most recent addition from each part of the site: one project, one publication,
          and one blog post.
        </p>
      </div>

      <div class="latest-grid">
        {
          latest.map((item) => (
            <article class="latest-card">
              <div class="latest-meta">
                <span>{item.type}</span>
                <span>{item.date}</span>
              </div>
              <h3><a href={item.href}>{item.title}</a></h3>
              <p>{item.description}</p>
              <a class="latest-link" href={item.href}>
                View {item.type.toLowerCase()} <Icon name="arrow" size={16} />
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="home-about section">
    <div class="shell home-about-grid">
      <p class="eyebrow">AI → knowledge → intelligent products</p>
      <div>
        <p>
          I started with questions and gradually learned how to turn answers into systems.
        </p>
        <a class="text-link" href="/about/">Read my story</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(48px, 6vw, 78px) 0 34px;
  }

  .home-hero :global(.display) {
    max-width: 760px;
    font-size: clamp(2.8rem, 5.8vw, 5.6rem);
    line-height: 0.98;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero-intro {
    max-width: 650px;
    margin: 30px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.35vw, 1.16rem);
  }

  .hero-copy :global(.button-row) {
    margin-top: 28px;
  }

  .capability-panel {
    position: relative;
    z-index: 2;
    padding: clamp(22px, 3vw, 32px);
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--panel);
    box-shadow: 0 32px 90px var(--shadow);
    backdrop-filter: blur(24px);
  }

  .panel-intro {
    margin: 0 0 18px;
    color: var(--muted);
    font-size: clamp(1.08rem, 1.55vw, 1.35rem);
  }

  .panel-intro strong {
    color: var(--accent-dark);
    font-weight: 600;
  }

  .capability-list article {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 12px;
    padding: 15px 0;
    border-top: 1px solid var(--line);
  }

  .capability-icon {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    color: var(--accent-dark);
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .capability-list h2,
  .capability-list p {
    margin: 0;
  }

  .capability-list h2 {
    font-size: 0.9rem;
  }

  .capability-list p {
    margin-top: 5px;
    color: var(--muted);
    font-size: 0.76rem;
  }

  .experience-strip {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 32px;
    align-items: center;
    padding: 20px 24px;
    margin-top: clamp(36px, 5vw, 58px);
    border: 1px solid var(--line);
    border-radius: 20px;
    background: var(--panel);
    box-shadow: 0 24px 70px var(--shadow);
    backdrop-filter: blur(20px);
  }

  .experience-heading {
    display: flex;
    min-width: 154px;
    flex-direction: column;
    gap: 3px;
    color: var(--faint);
    font-size: 0.68rem;
  }

  .experience-heading span {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .experience-heading strong {
    color: var(--muted);
    font-weight: 500;
  }

  .logo-marquee {
    display: flex;
    overflow: hidden;
    min-width: 0;
    padding-block: 6px;
    mask-image: linear-gradient(90deg, transparent, black 7%, black 93%, transparent);
  }

  .logo-track {
    display: flex;
    min-width: max-content;
    align-items: center;
    animation: logo-scroll 30s linear infinite;
  }

  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }

  .organization-logo {
    display: inline-flex;
    min-width: 150px;
    align-items: center;
    justify-content: center;
    padding-inline: 26px;
    color: var(--muted);
    white-space: nowrap;
  }

  .organization-logo img {
    width: auto;
    max-width: 118px;
    height: 32px;
    object-fit: contain;
    opacity: 0.58;
  }

  .organization-logo strong {
    font-size: 0.92rem;
    letter-spacing: 0.025em;
  }

  :global([data-theme="dark"]) .organization-logo img {
    opacity: 0.7;
  }

  @keyframes logo-scroll {
    to {
      transform: translateX(-100%);
    }
  }

  .network-field {
    position: absolute;
    z-index: 0;
    inset: auto -10% -8% -10%;
    height: 48%;
    opacity: 0.8;
    background:
      radial-gradient(ellipse at 25% 90%, rgba(30, 67, 230, 0.25), transparent 38%),
      radial-gradient(ellipse at 80% 80%, rgba(229, 34, 173, 0.32), transparent 40%);
  }

  .network-line {
    position: absolute;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(112, 78, 232, 0.7), rgba(235, 45, 178, 0.7), transparent);
    transform-origin: left;
  }

  .line-a { left: 8%; bottom: 26%; width: 35%; transform: rotate(-8deg); }
  .line-b { left: 30%; bottom: 32%; width: 34%; transform: rotate(10deg); }
  .line-c { right: 9%; bottom: 25%; width: 38%; transform: rotate(-13deg); }
  .line-d { left: 62%; bottom: 18%; width: 24%; transform: rotate(22deg); }

  .network-node {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 16px var(--accent);
  }

  .node-a { left: 12%; bottom: 28%; }
  .node-b { left: 34%; bottom: 37%; }
  .node-c { left: 58%; bottom: 27%; }
  .node-d { right: 18%; bottom: 36%; }
  .node-e { right: 5%; bottom: 18%; }

  .latest {
    border-top: 1px solid var(--line);
    background: rgba(9, 13, 36, 0.62);
  }

  .latest.section,
  .home-about.section {
    padding-block: clamp(56px, 7vw, 88px);
  }

  :global([data-theme="light"]) .latest {
    background: var(--surface);
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid var(--line);
  }

  .latest-card {
    display: flex;
    min-height: 330px;
    padding: clamp(22px, 2.5vw, 30px);
    flex-direction: column;
    background: var(--panel);
  }

  .latest-card + .latest-card {
    border-left: 1px solid var(--line);
  }

  .latest-meta {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    text-transform: uppercase;
  }

  .latest-card h3 {
    margin: 46px 0 16px;
    font-size: clamp(1.35rem, 2vw, 1.9rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .latest-card h3 a {
    text-decoration: none;
  }

  .latest-card h3 a:hover {
    color: var(--accent-dark);
  }

  .latest-card > p {
    margin: 0 0 32px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .latest-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }

  .home-about {
    border-top: 1px solid var(--line);
  }

  .home-about-grid {
    display: grid;
    grid-template-columns: 0.55fr 1.45fr;
    gap: clamp(40px, 8vw, 120px);
  }

  .home-about-grid > div > p {
    max-width: 900px;
    margin: 0 0 36px;
    font-size: clamp(1.45rem, 2.7vw, 2.55rem);
    letter-spacing: -0.045em;
    line-height: 1.18;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: auto;
    }

    .hero-grid,
    .home-about-grid {
      grid-template-columns: 1fr;
    }

    .experience-strip {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 20px 0;
    }

    .experience-heading {
      padding-inline: 20px;
    }

    .latest-grid {
      grid-template-columns: 1fr;
    }

    .latest-card {
      min-height: 290px;
    }

    .latest-card + .latest-card {
      border-top: 1px solid var(--line);
      border-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-marquee {
      overflow-x: auto;
      mask-image: none;
    }

    .logo-track {
      animation: none;
    }

    .logo-track[aria-hidden="true"] {
      display: none;
    }
  }
</style>
