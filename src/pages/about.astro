---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import {
  education,
  experience,
  researchProfiles,
  site,
  skillGroups,
  interestGroups,
} from "../data/site";
---

<BaseLayout
  title="About me"
  description="About Jenifer Tabita Ciuciu-Kiss, an AI engineer and PhD researcher working on knowledge graphs, ontology engineering, data engineering, and research software."
>
  <section class="section-compact bio">
    <div class="shell bio-grid">
      <figure class="portrait">
        <img
          src="/images/jenifer-ciuciu-kiss.jpg"
          alt="Jenifer Tabita Ciuciu-Kiss at a technology conference"
          width="900"
          height="1200"
          loading="eager"
        />
        <figcaption>
          Jenifer Tabita Ciuciu-Kiss · Zurich, Switzerland
        </figcaption>
      </figure>
      <div class="bio-copy">
        <p class="eyebrow">About me</p>
        <h1 class="section-title">
          AI engineer, researcher, and product builder.
        </h1>
        <h2>Who I am</h2>
        <p>
          I am an AI and data engineer based in Zurich and a PhD candidate in
          Artificial Intelligence at the Universidad Politécnica de Madrid. My
          research is supervised by
          <a href="https://dgarijo.com/" target="_blank" rel="noreferrer"
            >Dr. Daniel Garijo</a
          >
          in the Ontology Engineering Group.
        </p>
        <h2>What I work on</h2>
        <p>
          I build systems that turn complex or unstructured information into
          data people and software can use. My work includes knowledge graphs,
          ontology engineering, research software classification, document
          processing, machine learning, and data platforms.
        </p>
        <h2>Research and practical systems</h2>
        <p>
          My research asks how software and scientific knowledge can be
          classified, aligned, and reused. My engineering work tests those ideas
          against production constraints: imperfect data, reliability,
          maintainability, and the needs of the people using the system.
        </p>
        <h2>What I am interested in now</h2>
        <p>
          I am currently focused on intelligent knowledge systems, research
          software, document AI, semantic technologies, and products that
          combine structured knowledge with useful interfaces.
        </p>
        <div class="button-row">
          <a
            class="button button-primary"
            href={site.cv}
            target="_blank"
            rel="noreferrer"
          >
            Download CV <Icon name="download" />
          </a>
          <a class="button button-quiet" href="/projects/">Explore my work</a>
        </div>
        <div class="research-links" aria-label="Research profiles">
          {
            researchProfiles.map((profile) => (
              <a href={profile.href} target="_blank" rel="noreferrer">
                {profile.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section timeline-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Experience</p>
          <h2 class="section-title">Engineering, research, and teaching.</h2>
        </div>
        <p class="lead">
          Experience across production software, machine learning, data systems,
          ontology engineering, and technical education.
        </p>
      </div>
      <div class="timeline">
        {
          experience.map((item) => (
            <article class="timeline-item">
              <p class="timeline-period">{item.period}</p>
              <div>
                <h3>{item.role}</h3>
                <p class="timeline-org">
                  {item.organization} · {item.location}
                </p>
              </div>
              <p class="timeline-summary">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section education-section">
    <div class="shell grid-2">
      <div>
        <p class="eyebrow">Education</p>
        <h2 class="section-title">Computer science, data science, and AI.</h2>
      </div>
      <div>
        {
          education.map((item) => (
            <article class="education-item">
              <p>{item.period}</p>
              <h3>{item.degree}</h3>
              <strong>{item.institution}</strong>
              <span>{item.detail}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-compact skills-section">
    <div class="shell">
      <div class="skills-heading">
        <p class="eyebrow">Expertise</p>
      </div>

      <div class="grid-2 skill-grid">
        {
          skillGroups.map((group) => (
            <article class="skill-group">
              <h3>{group.title}</h3>
              <ul class="tag-list">
                {group.skills.map((skill) => (
                  <li class="tag">{skill}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-compact interests-section">
    <div class="shell">
      <div class="skills-heading">
        <p class="eyebrow">Beyond work</p>
      </div>

      <div class="grid-3 interest-grid">
        {
          interestGroups.map((interest) => (
            <article class="interest-card">
              <h3>{interest.title}</h3>
              <p>{interest.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bio {
    border-top: 1px solid var(--line);
  }

  .bio-grid {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }

  .portrait {
    position: sticky;
    top: 32px;
    width: 180px;
    margin: 0;
  }

  .portrait img {
    width: 180px;
    height: 180px;
    border: 1px solid var(--line);
    object-fit: cover;
    object-position: 50% 24%;
  }

  .portrait figcaption {
    margin-top: 12px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .bio-copy {
    max-width: 850px;
  }

  .bio-copy > h1 {
    margin-bottom: 48px;
  }

  .bio-copy > h2 {
    margin: 32px 0 8px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bio-copy > p {
    margin: 0 0 1.2em;
    font-size: clamp(1.02rem, 1.6vw, 1.3rem);
    letter-spacing: -0.025em;
    line-height: 1.55;
  }

  .bio-copy > p a {
    color: var(--accent-dark);
  }

  .research-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
    margin-top: 24px;
  }

  .research-links a {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .timeline-section,
  .skills-section {
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 160px 1fr 1.1fr;
    gap: clamp(24px, 5vw, 72px);
    padding: 32px 0;
    border-top: 1px solid var(--line);
  }

  .timeline-item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .timeline-period,
  .timeline-org,
  .education-item > p {
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    text-transform: uppercase;
  }

  .timeline-item h3,
  .timeline-item p {
    margin: 0;
  }

  .timeline-item h3 {
    font-size: 1.2rem;
  }

  .timeline-org {
    margin-top: 7px !important;
  }

  .timeline-summary {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .education-section {
    border-top: 1px solid var(--line);
  }

  .education-item {
    display: flex;
    padding: 28px 0;
    border-top: 1px solid var(--line);
    flex-direction: column;
  }

  .education-item h3 {
    margin: 10px 0 4px;
    font-size: 1.35rem;
  }

  .education-item strong {
    font-size: 0.88rem;
  }

  .education-item span {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .skill-grid {
    gap: 0 32px;
    border-top: 1px solid var(--line);
  }

  .skills-heading {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    align-items: baseline;
    margin-bottom: 28px;
  }

  .skills-heading .eyebrow {
    margin: 0;
  }

  .skills-heading h2 {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .skill-group {
    display: grid;
    grid-template-columns: minmax(150px, 0.75fr) minmax(0, 1.25fr);
    gap: 20px;
    align-items: start;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }

  .skill-group h3 {
    margin: 3px 0 0;
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .skill-group :global(.tag-list) {
    gap: 6px;
  }

  .skill-group :global(.tag) {
    padding: 6px 9px;
    font-size: 0.58rem;
  }

  @media (max-width: 760px) {
    .bio-grid,
    .timeline-item {
      grid-template-columns: 1fr;
    }

    .portrait {
      position: static;
      width: 140px;
    }

    .portrait img {
      width: 140px;
      height: 140px;
    }

    .timeline-item {
      gap: 12px;
    }

    .skills-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .skill-group {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .interests-section {
      border-top: 1px solid var(--line);
    }

    .interest-grid {
      margin-top: 28px;
    }

    .interest-card {
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--panel);
    }

    .interest-card h3 {
      margin: 0 0 10px;
      font-size: 1rem;
    }

    .interest-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.6;
    }
  }
</style>
